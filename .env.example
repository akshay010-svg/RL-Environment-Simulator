DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# ── JWT Authentication ────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── RL Engine Defaults ────────────────────────────────────
RL_MAX_STEPS=50
RL_NUM_AGENTS=3
RL_NUM_TICKETS=5
